<%- include('partials/header') %>

<main id="project-details-page">
    <h1><%= project.title %></h1>

    <p>
        <strong>Description:</strong> <%= project.description %>
    </p>

    <p>
        <strong>Date:</strong> <%= project.event_date %>
    </p>

    <p>
        <strong>Location:</strong> <%= project.location %>
    </p>

    <p>
        <strong>Organization:</strong>
        <a href="/organization/<%= project.organization_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <% if (categories && categories.length > 0) { %>
        <p>
            <strong>Categories:</strong>
            <% categories.forEach((category, index) => { %>
                <a href="/category/<%= category.category_id %>"><%= category.name %></a><%= index < categories.length - 1 ? ', ' : '' %>
            <% }) %>
        </p>
    <% } %>

    <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>

    <a href="/edit-project/<%= project.project_id %>">Edit Project</a>
</main>

<%- include('partials/footer') %>