<%- include('partials/header') %>

<main id="dashboard">
    <h1><%= title %></h1>

    <h2>Dashboard</h2>
    <p>Name: <%= name %></p>
    <p>Username: <%= email %></p>

    <h3>Your Volunteered Projects</h3>
    <% if (volunteeredProjects && volunteeredProjects.length > 0) { %>
        <ul>
            <% volunteeredProjects.forEach(project => { %>
                <li>
                    <a href="/project/<%= project.project_id %>"><%= project.title %></a> 
                    - <%= project.organization_name %> - <%= project.event_date %>
                    <form action="/project/<%= project.project_id %>/unvolunteer" method="POST" style="display: inline;">
                        <button type="submit">Remove</button>
                    </form>
                </li>
            <% }) %>
        </ul>
    <% } else { %>
        <p>You haven't volunteered for any projects yet.</p>
    <% } %>

    <% if (user && user.role_name === 'admin') { %>
        <p><a href="/users">View All Users</a></p>
    <% } %>

</main>

<%- include('partials/footer') %>