<%- include('partials/header') %>
<main id="users-page">
    <h1><%= title %></h1>
    
    <h2>Registered Users</h2>
    
    <% if (users && users.length > 0) { %>
        <table >
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email (Username)</th>
                    <th>Role</th>
                </tr>
            </thead>
            <tbody>
                <% users.forEach(user => { %>
                    <tr>
                        <td><%= user.name %></td>
                        <td><%= user.email %></td>
                        <td><%= user.role_name %></td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } else { %>
        <p>No users found.</p>
    <% } %>
</main>
<%- include('partials/footer') %>
